{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(go build ./...)",
            "Bash(go test ./...)",
            "Bash(go vet ./...)",
            "Bash(go doc:*)",
            "Bash(bun install)",
            "Bash(bun dev)",
            "Bash(bun build)",
            "Bash(bunx eslint .)",
            "Bash(docker compose *)",
            "Read(~/.zshrc)",
            "WebFetch(domain:adk.dev)"
        ],
        "deny": ["Read(**/.env)", "Read(**/.env.*)"]
    },
    "enabledPlugins": {
        "gopls-lsp@claude-plugins-official": true
    },
    "companyAnnouncements": ["Welcome to JAJA :)! Please don't ship JAJAs."]
}
